# ==============================================================================
# BuildWithAI (TRIZ MCP Workspace) - Environment Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# Google GenAI / Gemini API Credentials
# ------------------------------------------------------------------------------
# Provide your Gemini API Key.
# GOOGLE_GENAI_API_KEY is preferred by the modern @google/genai SDK.
GOOGLE_GENAI_API_KEY=your_gemini_api_key_here

# Fallback keys (if required by older ADK/Gemini libraries)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# ADK Agent Service (adg-agents)
# ------------------------------------------------------------------------------
# Port the ADK Agent service will run on locally.
ADK_AGENT_PORT=8081

# URL to connect the ADK Agent service to the TRIZ MCP Server.
# Local development: http://localhost:8000/mcp
# Docker Compose: http://mcp-server:8000/mcp
MCP_SERVER_URL=http://localhost:8000/mcp

# ------------------------------------------------------------------------------
# NestJS Backend API Gateway (apps/api)
# ------------------------------------------------------------------------------
# Port the NestJS API Gateway will run on.
PORT=3000

# URL to connect the API Gateway to the ADK Agent.
# Local development: http://localhost:8081
# Docker Compose: http://adk-agent:8081
ADK_AGENT_URL=http://localhost:8081

# ------------------------------------------------------------------------------
# TRIZ MCP Server (mcp-server)
# ------------------------------------------------------------------------------
# Host and port the FastMCP server listens on.
MCP_HOST=localhost
MCP_PORT=8000

# Name of the MCP server.
MCP_NAME=triz-mcp-server

# Enable or disable authorization (if supported).
AUTH_ENABLED=false

# ------------------------------------------------------------------------------
# Docker Compose Host Ports Configuration
# ------------------------------------------------------------------------------
# Port mappings for host access to services when using Docker Compose.
FRONTEND_PORT_HOST=4200
API_PORT_HOST=3000
ADK_PORT_HOST=8081
MCP_PORT_HOST=8000
DB_PORT_HOST=5432
