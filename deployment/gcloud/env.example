# Copy this file to deployment/gcloud/.env and fill in the values.
# The scripts read this as a bash env file, so quote values that contain spaces.

# Required Google Cloud project settings.
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1
GCP_ZONE=europe-west1-b

# Required Gemini credentials used by the ADK agent container.
GOOGLE_GENAI_API_KEY=replace-with-your-gemini-api-key

# Optional fallback keys. Leave empty to reuse GOOGLE_GENAI_API_KEY.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Deployment naming. Keep APP_NAME lowercase, numeric, or hyphenated.
APP_NAME=buildwithai

# Compute Engine VM sizing.
MACHINE_TYPE=e2-standard-2
BOOT_DISK_SIZE=50GB

# Network exposure.
# The app is served through the existing Docker Compose frontend mapping:
# http://VM_EXTERNAL_IP:4200
FRONTEND_PORT=4200
SSH_SOURCE_RANGE=0.0.0.0/0
HTTP_SOURCE_RANGE=0.0.0.0/0

# Set true only when you also want direct public access to API/agent/MCP ports.
EXPOSE_INTERNAL_PORTS=false

# Remote filesystem location on the VM.
REMOTE_APP_DIR=/opt/buildwithai

# Smoke test timeout after docker compose starts.
DEPLOY_HEALTH_TIMEOUT_SECONDS=900

# Verifies the frontend -> API -> ADK/Gemini path after containers are running.
# Set false to skip the LLM call during deployment.
RUN_AGENT_SMOKE_TEST=true
AGENT_SMOKE_TEST_TIMEOUT_SECONDS=180
